# ============================================
# Общий .env файл для всех сервисов
# При изменении ключей — измените только здесь
# ============================================

# Binance API Keys
BINANCE_API_KEY=YOUR_API_KEY_HERE
BINANCE_API_SECRET=YOUR_API_SECRET_HERE

# API Server
PORT=5000
BOT_DIR=./bot
DATABASE_PATH=./data/bot.db